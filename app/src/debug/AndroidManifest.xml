<?xml version="1.0" encoding="utf-8"?>
<!--
  DEBUG-ONLY manifest overlay (removable de-risk tooling).

  The base manifest declares .debug.AyaneoProbeReceiver as enabled="false"
  exported="false" so it is completely inert in release builds. This overlay,
  which the manifest merger only applies to the debug build type, flips it to
  enabled + exported so it can be triggered over adb:

    adb shell am broadcast \
      -a io.github.mayusi.calibratesoc.debug.PROBE_AYANEO \
      -n io.github.mayusi.calibratesoc.debug/io.github.mayusi.calibratesoc.debug.AyaneoProbeReceiver

  tools:replace overrides the enabled/exported attributes on the existing
  <receiver> declaration (the merger refuses a silent conflict otherwise) while
  leaving everything else — including the intent-filter — intact. Delete this
  whole file (and the base <receiver> block, and the debug/ package) once the
  probe question is answered.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application>
        <receiver
            android:name=".debug.AyaneoProbeReceiver"
            android:enabled="true"
            android:exported="true"
            tools:replace="android:enabled,android:exported" />
    </application>

</manifest>
