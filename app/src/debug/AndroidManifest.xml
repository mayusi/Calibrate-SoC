<?xml version="1.0" encoding="utf-8"?>
<!--
  DEBUG-ONLY manifest overlay (removable de-risk tooling).

  The base manifest declares .debug.RetroidFanProbeReceiver as
  android:enabled="false" android:exported="false" so it is completely
  inert in release builds. This overlay, applied ONLY to the debug build
  type by the manifest merger, flips it to enabled=true + exported=true
  so it can be triggered over adb.

  Trigger commands and log tag are documented in RetroidFanProbeReceiver.kt.

  tools:replace overrides the enabled/exported attributes on the existing
  receiver declaration while leaving the intent-filter intact. Delete this
  file, RetroidFanProbe.kt, RetroidFanProbeReceiver.kt, and the matching
  receiver block in the main manifest once the probe question is answered.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application>
        <receiver
            android:name=".debug.RetroidFanProbeReceiver"
            android:enabled="true"
            android:exported="true"
            tools:replace="android:enabled,android:exported" />
    </application>

</manifest>
