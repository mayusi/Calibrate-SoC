<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ rules-based backup mirror of backup_rules.xml. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="last_known_good.json" />
        <exclude domain="file" path="capability_cache.json" />
        <exclude domain="database" path="bench_history.db" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="last_known_good.json" />
        <exclude domain="file" path="capability_cache.json" />
        <exclude domain="database" path="bench_history.db" />
    </device-transfer>
</data-extraction-rules>
