<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      Reading capability + posting an opt-in anonymous device report
      to the crowdsourced device DB.
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Notifications: monitoring service + benchmark progress + overlay foreground svc. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Foreground service categories. Monitor + overlay run as
         FOREGROUND_SERVICE_SPECIAL_USE (perf/system tuning, no AOSP category). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Keep CPU awake during benchmark runs so a long sustained-throttle test
         can't be killed mid-sample. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!--
      Floating in-game HUD (RTSS analog). User grants this via system
      settings; we never auto-grant.
    -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"
        tools:ignore="ProtectedPermissions" />

    <!--
      Bound at runtime by ForegroundAppWatcher when the user grants
      Accessibility access. Declared so the system shows our entry
      in Settings > Accessibility > Installed apps.
    -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE"
        tools:ignore="ProtectedPermissions" />

    <!--
      Per-app profile switching: need PACKAGE_USAGE_STATS to read the
      current foreground package (Accessibility-service is the alternative
      pathway; we prefer usage stats where granted for lower overhead).
    -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!--
      The headline no-root capability on AYN handhelds: write to
      Settings.System keys like performance_mode and fan_mode. This is
      a signature/system permission, so Android won't grant it on a
      normal install — but it CAN be granted once via:

        adb shell pm grant io.github.mayusi.calibratesoc \
          android.permission.WRITE_SECURE_SETTINGS

      or through Shizuku once Shizuku is bound. The grant survives
      reboots. We must declare it here or pm grant silently no-ops
      because the runtime won't grant a permission the manifest never
      requested.
    -->
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />

    <!--
      DUMP enables `dumpsys gfxinfo <foreground pkg> framestats` so the
      HUD can show real game FPS. Same signature/protection level as
      WRITE_SECURE_SETTINGS — must be declared here or `pm grant DUMP`
      silently no-ops. The user grants it once by running our setup
      script via Odin Settings → Run script as Root.
    -->
    <uses-permission android:name="android.permission.DUMP"
        tools:ignore="ProtectedPermissions" />

    <!-- Re-apply boot-restore preset on cold boot when user opted in. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!--
      Lets us fire the direct "Allow background running?" system dialog
      (ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS). WITHOUT this declared,
      that intent throws and the Battery-optimization wizard step appears
      to do nothing. Normal (non-dangerous) permission, granted at install.
    -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!--
      Required to launch the system package installer for self-updates.
      Without this, the Intent.ACTION_VIEW + package-archive MIME causes
      a SecurityException on Android 8+ (API 26+).
    -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!--
      Needed to read every installed package's label/icon when building the
      per-app override picker (Android 11+ visibility restriction).
    -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <queries>
        <!-- Detect Shizuku peer + known vendor companion apps. The Odin 3
             firmware uses the com.odin.* namespace (internal classes are
             com.ro.*); older docs and Odin 2 firmware sometimes use
             com.ayn.* — query both so detection works regardless. -->
        <package android:name="moe.shizuku.privileged.api" />
        <package android:name="com.odin.gameassistant" />
        <package android:name="com.odin.settings" />
        <package android:name="com.ayn.gameassistant" />
        <package android:name="de.langerhans.odintools" />
        <package android:name="com.ayaneo.ayaspace" />
        <!-- AYANEO Pocket DS vendor apps. Verified by live probe on the
             physical device. AYASpace is absent on this model; these are
             the actual vendor packages that fulfil the same role. -->
        <package android:name="com.ayaneo.settings" />
        <package android:name="com.aya.gsset" />
        <package android:name="com.ayaneo.gamewindow" />
        <package android:name="com.ayaneo.gamelauncher" />
        <package android:name="com.ayaneo.home" />
        <!-- Retroid Pocket 6 vendor apps (verified live on RP6).
             com.rp.settings hosts the "run script as root" runner
             (same com.ro.* firmware base as Odin). -->
        <package android:name="com.rp.gameassistant" />
        <package android:name="com.rp.settings" />
        <package android:name="com.retroidpocket.gamelauncher" />
        <package android:name="com.retroidpocket.gameassistant" />

        <!-- resolveActivity() for Odin's fan-curve editor deep link
             needs this <intent> filter on Android 11+ or it returns null
             even when the target Activity is exported. -->
        <intent>
            <action android:name="action_fan_temp_control_curve_config" />
        </intent>

        <!-- Benchmark Hub: popular third-party benchmark apps.
             Android 11+ (API 30+) requires these <package> entries for
             PackageManager.getLaunchIntentForPackage() to return a non-null
             result when checking if the app is installed. Without this block
             the API always returns null even when the app is present.

             LEGAL: we only detect install status and LAUNCH the apps via the
             system start-activity mechanism. We do NOT scrape their scores,
             read their result files, or use accessibility services on them. -->
        <package android:name="com.futuremark.dmandroid.application" />   <!-- 3DMark -->
        <package android:name="com.antutu.ABenchMark" />                  <!-- AnTuTu -->
        <package android:name="com.primatelabs.geekbench6" />             <!-- Geekbench 6 -->
        <package android:name="com.glbenchmark.glbenchmark27" />          <!-- GFXBench -->
        <package android:name="skynet.cputhrottlingtest" />               <!-- CPU Throttling Test -->
        <package android:name="com.futuremark.pcmark.android.benchmark" /> <!-- PCMark -->

        <!-- Battery-optimization settings screens. Android 11+ package
             visibility hides these from startActivity() unless declared,
             which is why the fallback "open the battery list" path could
             silently fail on some firmwares. -->
        <intent>
            <action android:name="android.settings.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
        </intent>
        <intent>
            <action android:name="android.settings.IGNORE_BATTERY_OPTIMIZATION_SETTINGS" />
        </intent>
        <intent>
            <action android:name="android.settings.APPLICATION_DETAILS_SETTINGS" />
        </intent>
    </queries>

    <application
        android:name=".CalibrateSocApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.CalibrateSoC"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.CalibrateSoC">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          Benchmark crash isolation. The native CPU + (future) Vulkan
          benchmark kernels run inside the :bench process so a native
          crash can't kill the dashboard / monitor service. Service
          declaration deferred until BenchmarkService lands; the
          android:process attribute on the service binding will route
          to ":bench".
        -->

        <!--
          FileProvider for sharing generated AYN tuning scripts with
          Odin Settings' "Run script as Root" picker. Required because
          Android 7+ blocks file:// URIs across app boundaries.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

        <!-- Shizuku provider hook: lets Shizuku auto-grant peer permission. -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:enabled="true"
            android:exported="true"
            android:multiprocess="false"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <!--
          BOOT_COMPLETED revert: by default every sysfs tunable we wrote
          during the previous session reverts to its pre-write value at
          boot. Profiles marked applyOnBoot are then re-applied on top
          of the reverted baseline.
        -->
        <receiver
            android:name=".data.tunables.BootRevertReceiver"
            android:exported="false"
            android:enabled="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!--
          No-root "persistent" script path: posts a post-boot notification
          asking the user to re-run their tune via Odin Settings. Only
          fires when the user has explicitly registered one or more
          presets via Tune → Generate script → Remind me at boot.
        -->
        <receiver
            android:name=".data.script.BootScriptReminderReceiver"
            android:exported="false"
            android:enabled="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!--
          Auto-configure known games: the "Undo / don't auto-tune this app"
          action on the auto-config notification fires this receiver. It removes
          the auto-created bundle (only if still auto-created) and records the
          package in the opt-out set so it is never re-created. Internal only —
          never exported (the PendingIntent is created in-process).
        -->
        <receiver
            android:name=".data.profiles.AutoConfigUndoReceiver"
            android:exported="false"
            android:enabled="true" />

        <!--
          DE-RISK PROBE (debug-only, removable). Answers one question: can a
          normal (non-system) app bind SettingsController → FanProvider on the
          Retroid Pocket 6 and drive the fan? Used ONLY to de-risk the RP6 fan-
          curve feature before building the full RetroidVendorWriter.

          Disabled + un-exported here so it is COMPLETELY INERT in release
          builds — the receiver is never instantiated, never receives intents,
          and appears in the merged release manifest as a dead entry only. The
          debug-only manifest overlay (src/debug/AndroidManifest.xml) flips it
          to enabled=true + exported=true for debug builds via tools:replace.
          RetroidFanProbeReceiver.onReceive() also hard-returns unless
          BuildConfig.DEBUG as a second guard.

          Delete this block, src/debug/AndroidManifest.xml, RetroidFanProbe.kt,
          and RetroidFanProbeReceiver.kt once the probe question is answered.
        -->
        <receiver
            android:name=".debug.RetroidFanProbeReceiver"
            android:enabled="false"
            android:exported="false">
            <intent-filter>
                <action android:name="io.github.mayusi.calibratesoc.debug.PROBE_RETROID_FAN" />
            </intent-filter>
        </receiver>

        <!--
          Floating HUD overlay. TYPE_APPLICATION_OVERLAY foreground
          service so the panel survives the user backgrounding our
          app and switching into a game. SPECIAL_USE category — no
          AOSP category covers "perf monitor / on-screen tuner".
        -->
        <service
            android:name=".ui.overlay.OverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="floating performance HUD overlay" />
        </service>

        <!--
          AutoTDP LIVE daemon. Writes cpu$N/online, scaling_max_freq, and
          GPU max_pwrlevel on a 1 Hz telemetry loop; reverts all writes on
          stop via TunableWriter's snapshot journal. SPECIAL_USE — dynamic
          power management / CPU & GPU tuning, no AOSP category covers this.
          Only starts on devices where the needed sysfs nodes are writable
          (root / unlock-script tier); otherwise it self-stops and exposes
          a reason for the UI to route to SCRIPT/ADVISORY.
        -->
        <service
            android:name=".data.autotdp.AutoTdpService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="dynamic CPU and GPU power management daemon" />
        </service>

        <!--
          Game Boost LIVE daemon (WAVE 3a). Brute-pins every cluster + GPU + bus to
          the ceiling for raw FPS, time-boxed and thermally guarded; reverts all
          writes on stop / timeout / thermal-trip via TunableWriter's snapshot
          journal. SPECIAL_USE — max-performance CPU & GPU pinning, no AOSP category
          covers this. Mutually exclusive with AutoTDP (both write clocks).
        -->
        <service
            android:name=".data.boost.GameBoostService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="max-performance CPU and GPU pin daemon" />
        </service>

        <!--
          Predictive Throttle Guard LIVE daemon (WAVE 3a). Feeds telemetry into the
          PredictiveThrottleGuard forecaster and pre-emptively caps the big cluster a
          little before the kernel's throttle cliff so FPS degrades smoothly; reverts
          the cap when the forecast clears and on stop. Auto-suppressed while AutoTDP
          or Game Boost owns the clocks. SPECIAL_USE — thermal pre-empt tuning.
        -->
        <service
            android:name=".data.thermal.ThrottleGuardService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="predictive thermal throttle guard daemon" />
        </service>

        <!--
          Quick Settings tile to toggle the HUD without opening the app.
          The user has to drag this into their tile tray via Edit tiles
          once — Android won't auto-add system tiles to the active set.
        -->
        <service
            android:name=".ui.overlay.HudQuickTileService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/hud_tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!--
          Foreground-app watcher for per-app profile auto-switching.
          Disabled until the user explicitly grants Accessibility access
          (Settings > Accessibility > Installed apps > Calibrate SoC).
          Without that grant the service class exists but receives no
          events, so per-app overrides become a no-op.
        -->
        <service
            android:name=".data.profiles.ForegroundAppWatcher"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>
    </application>

</manifest>
